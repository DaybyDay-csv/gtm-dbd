# =====================================================================
# GTM Factory (gtm-dbd) — Environment variables
# =====================================================================
# Real .env is gitignored. Copy this file to .env and fill in real values
# for local dev. Production values are set in:
#   - Lovable Project Settings (frontend vars)
#   - Supabase Edge Function Secrets (backend vars via `supabase secrets set`)
# =====================================================================

# ---------------------------------------------------------------------
# Frontend (Vite) — exposed to the browser via import.meta.env
# Set these in Lovable Project Settings
# ---------------------------------------------------------------------
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# ---------------------------------------------------------------------
# Backend (Supabase Edge Functions) — NEVER exposed to the browser
# Set via: supabase secrets set LOVABLE_API_KEY=...
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected)
# ---------------------------------------------------------------------
# Required: AI gateway for all 7 phase functions
LOVABLE_API_KEY=your-lovable-gateway-key

# Optional: Phase 3 (real audit layer) — all free Google Cloud APIs
# Get them at https://console.cloud.google.com/apis/credentials
# Restrict each key to specific APIs + HTTP referrers for safety
GOOGLE_PAGESPEED_API_KEY=
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
GOOGLE_KNOWLEDGE_GRAPH_API_KEY=
GOOGLE_YOUTUBE_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
GOOGLE_RECAPTCHA_SECRET_KEY=
GOOGLE_MAPS_API_KEY=

# Optional: Phase 2 (Stripe deposit for paid audit)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEPOSIT_PRICE_ID=
